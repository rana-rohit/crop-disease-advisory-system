# Model Configuration
CROP_DISEASE_MODEL_PATH=backend/model/artifacts/crop_disease_mobilenetv2.keras
CROP_DISEASE_CLASS_NAMES_PATH=backend/model/artifacts/class_names.json
CROP_DISEASE_INFO_PATH=backend/disease_data/disease_info.json

# Inference Configuration
CONFIDENCE_THRESHOLD=80.0
TOP_K_PREDICTIONS=3
MODEL_VERSION=mobilenetv2-plantvillage-v1
CALIBRATION_ENABLED=False
CONFIDENCE_TEMPERATURE=1.0

# Security & Uploads
MAX_UPLOAD_SIZE_MB=5
MAX_IMAGE_PIXELS=12000000

# Application Settings
FLASK_ENV=development
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Logging
LOG_LEVEL=INFO
